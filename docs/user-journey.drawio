                edge="1" source="iot-poll" target="iot-decide" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-decide-proactive" value="異常"
                style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontStyle=1;fontSize=10;"
                edge="1" source="iot-decide" target="care-proactive" parent="1">
          <mxGeometry relative="1" as="geometry" />
