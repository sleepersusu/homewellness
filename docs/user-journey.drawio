                edge="1" source="care-proactive" target="respond-decide" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e-respond-yes" value="有回應"
                style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontStyle=2;fontSize=10;"
                edge="1" source="respond-decide" target="comfort-ok" parent="1">
